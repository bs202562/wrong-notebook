{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/notebooks/layout,_N_T_/notebooks/page,_N_T_/notebooks"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/notebooks/__PAGE__",
    "/notebooks",
    "/_index",
    "/_head"
  ]
}