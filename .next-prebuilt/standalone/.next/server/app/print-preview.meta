{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/print-preview/layout,_N_T_/print-preview/page,_N_T_/print-preview"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/print-preview/__PAGE__",
    "/print-preview",
    "/_index",
    "/_head"
  ]
}