# 数据库连接地址
# 本地开发通常使用 SQLite，路径相对于 prisma/schema.prisma
DATABASE_URL="file:./dev.db"

# NextAuth 会话加密密钥
# 生产环境必须修改！可以使用 `openssl rand -base64 32` 生成
NEXTAUTH_SECRET="supersecret-dev-secret"

# 应用的基础 URL
# 本地开发通常是 http://localhost:3000
# 生产环境如果使用 Docker 且 IP 不固定，建议注释掉此项并启用 AUTH_TRUST_HOST
# NEXTAUTH_URL="http://localhost:3000"

# 信任 Host 请求头
# 设置为 true 时，NextAuth 会根据请求头自动推断 URL，适合 Docker/PaaS 环境
AUTH_TRUST_HOST=true

# AI 服务提供商配置
# 可选值: "gemini" (默认)、"openai"、"azure" 或 "qwen"
AI_PROVIDER="gemini"

# OpenAI 配置 (当 AI_PROVIDER="openai" 时需要)
OPENAI_API_KEY=""
OPENAI_BASE_URL="" # 可选，用于兼容的 API 服务
OPENAI_MODEL="gpt-4o" # 可选，默认为 gpt-4o

# Google Gemini 配置 (当 AI_PROVIDER="gemini" 时需要)
GOOGLE_API_KEY=""
GEMINI_BASE_URL="" # 可选，用于自定义 API 地址
GEMINI_MODEL="gemini-2.5-flash" # 可选，默认为 gemini-2.5-flash

# 通义千问 Qwen 配置 (当 AI_PROVIDER="qwen" 时需要)
# API Key 从阿里云百炼控制台获取: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=""
QWEN_BASE_URL="" # 可选，默认为 https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL="qwen-vl-max" # 可选，默认为 qwen-vl-max（图片识别需要视觉模型）

# 日志配置
# 日志级别: trace, debug, info, warn, error, fatal
# 开发环境建议使用 debug，生产环境建议使用 info
LOG_LEVEL="debug"

# Database Debugging
# Set to "true" to enable SQL query logging
DEBUG_DB="false"

# Openclaw Agent API 配置
# 用于对接本地部署的 Openclaw agent 进行错题识别
OPENCLAW_API_URL="http://localhost:8080"  # Openclaw agent 服务地址
OPENCLAW_API_KEY=""  # Openclaw API 密钥
OPENCLAW_TIMEOUT=30000  # 请求超时时间（毫秒），默认30秒

# 本系统 API 认证模式配置
# 可选值: "credentials" (用户名密码登录，默认) 或 "apikey" (API Key认证)
OPENCLAW_AUTH_MODE="credentials"

# 本系统 API 密钥（用于 Openclaw agent 调用本系统）
# 仅当 OPENCLAW_AUTH_MODE=apikey 时需要配置
# 生成方式: openssl rand -hex 32
OPENCLAW_INTEGRATION_API_KEY=""
